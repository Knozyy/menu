# ---- Sunucu ----
PORT=3000
NODE_ENV=development

# ---- Oturum ----
# Üretimde MUTLAKA uzun, rastgele bir değerle değiştirin.
SESSION_SECRET=degistir-bunu-uzun-rastgele-bir-deger
# HTTPS (SSL) arkasında çalışıyorsanız true yapın. Düz HTTP'de false olmalı.
COOKIE_SECURE=false

# ---- İşletme / Marka ----
BRAND_NAME=Çam Vadisi
ACCENT_COLOR=#2563eb
DEFAULT_LANG=tr

# ---- İlk admin kullanıcısı (yalnızca DB boşsa oluşturulur) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=1234
