# ---- Sunucu ----
PORT=3000
NODE_ENV=development

# ---- HTTPS (opsiyonel, yerel test) ----
# TLS_CERT ve TLS_KEY tanımlıysa uygulama ek olarak HTTPS de dinler.
# Yerel sertifika üret:  mkcert localhost 127.0.0.1   (veya openssl ile self-signed)
# TLS_CERT=./localhost+2.pem
# TLS_KEY=./localhost+2-key.pem
# HTTPS_PORT=2443

# ---- Oturum ----
# Üretimde MUTLAKA uzun, rastgele bir değerle değiştirin.
SESSION_SECRET=degistir-bunu-uzun-rastgele-bir-deger
# HTTPS (SSL) arkasında çalışıyorsanız true yapın. Düz HTTP'de false olmalı.
COOKIE_SECURE=false

# ---- İşletme / Marka ----
BRAND_NAME=Çam Vadisi
ACCENT_COLOR=#2563eb
DEFAULT_LANG=tr

# ---- İlk admin kullanıcısı (yalnızca DB boşsa oluşturulur) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=1234
