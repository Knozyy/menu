<%- include('partials/head', { title: title }) %>
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;text-align:center">
  <div style="animation:pop .4s ease both">
    <div class="mono" style="font-size:64px;font-weight:800;color:var(--accent);letter-spacing:-2px"><%= code %></div>
    <div style="font-size:16px;color:var(--muted);margin:8px 0 20px;max-width:360px"><%= message %></div>
    <a href="/" class="hov-accent" style="display:inline-flex;height:44px;align-items:center;padding:0 20px;border-radius:11px;background:var(--accent);color:var(--on-accent);font-size:14.5px;font-weight:700;box-shadow:var(--shadow)"><%= brand %></a>
  </div>
</div>
</body>
</html>
