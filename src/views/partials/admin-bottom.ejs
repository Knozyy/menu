    </main>
  </div>

  <!-- Alt navigasyon (mobil) -->
  <nav class="bottom-nav" style="position:fixed;left:0;right:0;bottom:0;z-index:40;background:var(--surface);border-top:1px solid var(--border);padding:6px 6px max(6px,env(safe-area-inset-bottom));box-shadow:0 -2px 12px rgba(0,0,0,.06)">
    <% nav.forEach(function(n){ const active = n.key === activeNav; %>
      <a href="<%= n.href %>" style="flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:7px 4px;text-decoration:none;<%= active ? 'color:var(--accent)' : 'color:var(--muted)' %>">
        <span style="display:flex;width:22px;height:22px"><%- n.icon %></span>
        <span style="font-size:10.5px;font-weight:600"><%= n.label %></span>
      </a>
    <% }); %>
    <form method="POST" action="/admin/logout" style="flex:1;display:flex">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" style="flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:7px 4px;border:none;background:none;color:var(--muted);cursor:pointer;font-family:inherit">
        <span style="display:flex;width:22px;height:22px"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M15 17l5-5-5-5M20 12H9M9 4H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        <span style="font-size:10.5px;font-weight:600"><%= t.logout %></span>
      </button>
    </form>
  </nav>

</div>
<script src="/js/admin.js" defer></script>
</body>
</html>
