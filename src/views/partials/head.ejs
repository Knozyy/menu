<!DOCTYPE html>
<html lang="<%= lang %>" data-theme="<%= theme %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="<%= theme === 'dark' ? '#0d0f13' : '#f3f4f6' %>">
  <title><%= typeof title !== 'undefined' && title ? title + ' · ' + brand : brand %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <% if (String(accent).toLowerCase() !== '#2563eb') { %>
  <style>:root{--accent:<%= accent %>;--accent-hover:<%= accent %>;--accent-soft:<%= accentSoft %>;}</style>
  <% } %>
</head>
<body>
