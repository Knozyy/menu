<!DOCTYPE html>
<html lang="<%= lang %>" data-theme="<%= theme %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="<%= theme === 'dark' ? '#0d1016' : '#f4f6fc' %>">
  <title><%= brand %> · <%= lang === 'tr' ? 'Menü' : 'Menu' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/menu.css">
</head>
<body>
<% function L(tr, en){ return (lang === 'en' && en) ? en : tr; } %>
<div class="menu-shell" id="top">

  <!-- Sticky başlık + kategori çipleri + arama -->
  <header class="menu-header">
    <form method="POST" action="/prefs/lang" class="lang-toggle">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" aria-label="<%= lang === 'tr' ? 'Switch to English' : 'Türkçe\'ye geç' %>"><%= langLabel %></button>
    </form>
    <div class="brand-row">
      <div class="brand"><%= brand %></div>
      <div class="tagline"><%= lang === 'tr' ? 'Dijital Menü' : 'Digital Menu' %></div>
    </div>
    <% if (categories.length) { %>
      <nav class="chips" id="catNav">
        <% categories.forEach(function(c, i){ %>
          <a href="#cat-<%= c.id %>" class="chip<%= i === 0 ? ' active' : '' %>" data-target="cat-<%= c.id %>"><%= L(c.name, c.name_en) %></a>
        <% }); %>
      </nav>
    <% } %>
    <div class="search-wrap" id="searchWrap">
      <input id="dishSearch" type="search" inputmode="search" placeholder="<%= lang === 'tr' ? 'Yemek ara…' : 'Search dishes…' %>" autocomplete="off">
    </div>
  </header>

  <main>
    <% if (!categories.length) { %>
      <div class="no-results" style="display:block"><%= lang === 'tr' ? 'Menü yakında' : 'Menu coming soon' %></div>
    <% } %>

    <% categories.forEach(function(c){ %>
      <section class="cat-section" id="cat-<%= c.id %>" data-cat>
        <h2 class="cat-title"><%= L(c.name, c.name_en) %></h2>
        <div class="dish-list">
          <% c.items.forEach(function(p){ %>
            <article class="dish" data-dish data-name="<%= (p.name + ' ' + (p.name_en || '') + ' ' + (p.description || '') + ' ' + (p.description_en || '')).toLowerCase() %>">
              <% if (p.image_url) { %>
                <div class="dish-photo" style="background-image:url('<%= encodeURI(p.image_url) %>')"></div>
              <% } else { %>
                <div class="dish-photo empty">
                  <svg width="38" height="38" viewBox="0 0 24 24" fill="none"><path d="M7 3v8a2 2 0 0 0 2 2v8M11 3v8M9 3v4M16 3c-1.2 0-2 1.6-2 4s.8 4 2 4m0 0v6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
              <% } %>
              <div class="dish-body">
                <div class="dish-head">
                  <h3 class="dish-name"><%= L(p.name, p.name_en) %></h3>
                  <span class="dish-price"><%= fmt(p.price) %></span>
                </div>
                <% var dd = L(p.description, p.description_en); if (dd) { %><p class="dish-desc"><%= dd %></p><% } %>
              </div>
            </article>
          <% }); %>
        </div>
      </section>
    <% }); %>

    <div class="no-results" id="noResults"><%= lang === 'tr' ? 'Eşleşen ürün yok' : 'No matching items' %></div>
  </main>

  <footer class="menu-foot">
    <%= brand %> · <%= lang === 'tr' ? 'yalnızca görüntüleme' : 'view only' %>
  </footer>

  <!-- Alt navigasyon (view-only: sipariş/sepet yok) -->
  <nav class="tabbar">
    <button type="button" class="tab active" data-act="top">
      <svg viewBox="0 0 24 24" fill="none"><path d="M3 11l9-8 9 8M5 10v10h5v-6h4v6h5V10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span><%= lang === 'tr' ? 'Menü' : 'Menu' %></span>
    </button>
    <button type="button" class="tab" data-act="search">
      <svg viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="M21 21l-4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      <span><%= lang === 'tr' ? 'Ara' : 'Search' %></span>
    </button>
    <button type="button" class="tab" data-act="cats">
      <svg viewBox="0 0 24 24" fill="none"><path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="7" cy="6" r="1.4" fill="currentColor"/><circle cx="7" cy="12" r="1.4" fill="currentColor"/><circle cx="7" cy="18" r="1.4" fill="currentColor"/></svg>
      <span><%= lang === 'tr' ? 'Kategoriler' : 'Categories' %></span>
    </button>
    <form method="POST" action="/prefs/theme" style="flex:1;display:flex">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="tab" style="width:100%">
        <% if (theme === 'dark') { %>
          <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="2"/><path d="M12 2v2M12 20v2M4 12H2M22 12h-2M5 5l1.5 1.5M17.5 17.5L19 19M19 5l-1.5 1.5M6.5 17.5L5 19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        <% } else { %>
          <svg viewBox="0 0 24 24" fill="none"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
        <% } %>
        <span><%= lang === 'tr' ? 'Tema' : 'Theme' %></span>
      </button>
    </form>
  </nav>

  <!-- Kategori seçici (alt-panel) — "Kategoriler" butonu açar -->
  <div class="sheet-backdrop" id="sheetBackdrop"></div>
  <aside class="sheet" id="catSheet" role="dialog" aria-modal="true" aria-label="<%= lang === 'tr' ? 'Kategoriler' : 'Categories' %>">
    <div class="sheet-grip"></div>
    <div class="sheet-head">
      <span class="sheet-title"><%= lang === 'tr' ? 'Kategoriler' : 'Categories' %></span>
      <button type="button" class="sheet-close" id="sheetClose" aria-label="<%= lang === 'tr' ? 'Kapat' : 'Close' %>">×</button>
    </div>
    <div class="sheet-list">
      <% categories.forEach(function(c){ %>
        <button type="button" class="sheet-item" data-target="cat-<%= c.id %>">
          <span><%= L(c.name, c.name_en) %></span>
          <span class="count"><%= c.items.length %></span>
        </button>
      <% }); %>
    </div>
  </aside>

</div>
<script src="/js/menu.js" defer></script>
</body>
</html>
