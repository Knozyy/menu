<%- include('../partials/head', { title: t.login_title }) %>

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;position:relative;overflow:hidden">
  <div style="position:absolute;inset:0;background:radial-gradient(900px 500px at 50% -10%,var(--accent-soft),transparent 70%);pointer-events:none"></div>

  <div style="width:100%;max-width:404px;position:relative;animation:pop .4s ease both">
    <div style="display:flex;flex-direction:column;align-items:center;gap:14px;margin-bottom:22px">
      <div style="width:52px;height:52px;border-radius:15px;background:var(--accent);color:var(--on-accent);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:20px;letter-spacing:.5px;box-shadow:var(--shadow)">ÇV</div>
      <div style="text-align:center">
        <div style="font-size:20px;font-weight:700;letter-spacing:-.2px"><%= brand %></div>
        <div style="font-size:13.5px;color:var(--muted);margin-top:2px"><%= t.login_sub %></div>
      </div>
    </div>

    <form method="POST" action="/admin/login" style="background:var(--surface);border:1px solid var(--border);border-radius:18px;box-shadow:var(--shadow-lg);padding:26px">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <h1 style="margin:0 0 18px;font-size:17px;font-weight:700"><%= t.login_title %></h1>

      <% if (error) { %>
        <div role="alert" style="display:flex;gap:10px;align-items:flex-start;background:var(--danger-soft);border:1px solid var(--danger);color:var(--danger);border-radius:11px;padding:10px 12px;font-size:13px;margin-bottom:14px;animation:slidein .25s ease both">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" style="flex:none;margin-top:1px"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M12 7v6M12 16.5v.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          <span><%= error %></span>
        </div>
      <% } %>

      <label style="display:block;font-size:12.5px;font-weight:600;color:var(--muted);margin-bottom:6px"><%= t.username %></label>
      <input name="username" autocomplete="username" value="<%= username %>" placeholder="<%= t.username_ph %>" style="width:100%;height:44px;padding:0 14px;border:1px solid var(--border-strong);border-radius:11px;background:var(--surface-2);color:var(--text);font-size:14.5px;font-family:inherit;margin-bottom:14px">

      <label style="display:block;font-size:12.5px;font-weight:600;color:var(--muted);margin-bottom:6px"><%= t.password %></label>
      <input name="password" type="password" autocomplete="current-password" placeholder="••••••••" style="width:100%;height:44px;padding:0 14px;border:1px solid var(--border-strong);border-radius:11px;background:var(--surface-2);color:var(--text);font-size:14.5px;font-family:inherit;margin-bottom:18px">

      <button type="submit" class="hov-accent" style="width:100%;height:46px;border:none;border-radius:11px;background:var(--accent);color:var(--on-accent);font-size:15px;font-weight:700;font-family:inherit;cursor:pointer;box-shadow:var(--shadow);transition:background .15s"><%= t.login_btn %></button>
    </form>

    <div style="margin-top:16px;padding:0 10px;display:flex;align-items:center;justify-content:space-between;gap:12px">
      <span style="font-size:12px;color:var(--muted-2)" class="mono"><%= t.demo_hint %></span>
      <div style="display:flex;gap:6px">
        <form method="POST" action="/prefs/lang"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" title="Language" style="height:30px;padding:0 11px;border:1px solid var(--border);border-radius:8px;background:var(--surface);color:var(--text);font-size:12px;font-weight:700;font-family:inherit;cursor:pointer"><%= langLabel %></button>
        </form>
        <form method="POST" action="/prefs/theme"><input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" title="Theme" style="width:30px;height:30px;border:1px solid var(--border);border-radius:8px;background:var(--surface);color:var(--text);cursor:pointer;display:flex;align-items:center;justify-content:center">
            <% if (theme === 'dark') { %>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="2"/><path d="M12 2v2M12 20v2M4 12H2M22 12h-2M5 5l1.5 1.5M17.5 17.5L19 19M19 5l-1.5 1.5M6.5 17.5L5 19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            <% } else { %>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
            <% } %>
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
</body>
</html>
