<%- include('../partials/head', { title: pageTitle }) %>
<%- include('../partials/admin-top') %>

<div class="animate-pop">
  <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:18px;flex-wrap:wrap">
    <div>
      <div style="font-size:13px;color:var(--muted)"><%= t.dash_welcome %></div>
      <h2 style="margin:2px 0 0;font-size:22px;font-weight:800;letter-spacing:-.4px"><%= brand %></h2>
    </div>
  </div>

  <!-- İstatistik kartları -->
  <div class="stat-grid" style="margin-bottom:18px">
    <%
      const STAT_ICON = {
        cats: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="7" cy="6" r="1.3" fill="currentColor"/><circle cx="7" cy="12" r="1.3" fill="currentColor"/><circle cx="7" cy="18" r="1.3" fill="currentColor"/></svg>',
        prods: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M21 8l-9-5-9 5 9 5 9-5zM3 8v8l9 5 9-5V8M12 13v8" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>',
        check: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>',
        money: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
      };
      const cards = [
        { icon: STAT_ICON.cats,  value: stats.catCount,        label: t.total_categories, tag: 'OK' },
        { icon: STAT_ICON.prods, value: stats.prodCount,       label: t.total_products,   tag: 'OK' },
        { icon: STAT_ICON.check, value: stats.availCount,      label: t.available_products, tag: stats.availPct + '%' },
        { icon: STAT_ICON.money, value: fmt(stats.avg),        label: t.avg_price,        tag: 'AVG' },
      ];
      cards.forEach(function(s){ %>
      <div style="background:var(--surface);border:1px solid var(--border);border-radius:15px;padding:18px;box-shadow:var(--shadow-sm)">
        <div style="display:flex;align-items:center;justify-content:space-between">
          <span style="width:38px;height:38px;border-radius:11px;background:var(--accent-soft);color:var(--accent);display:flex;align-items:center;justify-content:center"><%- s.icon %></span>
          <span style="font-size:11.5px;font-weight:700;color:var(--ok);background:var(--ok-soft);padding:3px 8px;border-radius:20px"><%= s.tag %></span>
        </div>
        <div class="mono" style="font-size:30px;font-weight:800;letter-spacing:-1px;margin-top:14px"><%= s.value %></div>
        <div style="font-size:13px;color:var(--muted);margin-top:2px"><%= s.label %></div>
      </div>
    <% }); %>
  </div>

  <div class="dash-split">
    <!-- Son ürünler -->
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:15px;box-shadow:var(--shadow-sm);overflow:hidden">
      <div style="padding:14px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
        <h3 style="margin:0;font-size:14.5px;font-weight:700"><%= t.recent_products %></h3>
        <a href="/admin/products" style="font-size:12.5px;font-weight:700;color:var(--accent)"><%= t.view_all %></a>
      </div>
      <% recent.forEach(function(p){ %>
        <div style="display:flex;align-items:center;gap:12px;padding:11px 16px;border-bottom:1px solid var(--border)">
          <span style="width:42px;height:42px;border-radius:9px;flex:none;background-size:cover;background-position:center;<%- p.image_url ? ('background-image:url(' + encodeURI(p.image_url) + ')') : 'background-image:repeating-linear-gradient(45deg,var(--surface-2),var(--surface-2) 7px,var(--surface-3) 7px,var(--surface-3) 14px)' %>"></span>
          <div style="flex:1;min-width:0">
            <div style="font-size:14px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= p.name %></div>
            <div style="font-size:12px;color:var(--muted)"><%= p.category_name %></div>
          </div>
          <span class="mono" style="font-size:13px;font-weight:700"><%= fmt(p.price) %></span>
          <span style="font-size:11px;font-weight:700;padding:3px 8px;border-radius:20px;<%= p.is_available ? 'background:var(--ok-soft);color:var(--ok)' : 'background:var(--danger-soft);color:var(--danger)' %>"><%= p.is_available ? t.st_available : t.st_out %></span>
        </div>
      <% }); %>
      <% if (!recent.length) { %><div style="padding:24px 16px;font-size:13px;color:var(--muted)"><%= t.no_products %></div><% } %>
    </div>

    <!-- Sağ kolon -->
    <div style="display:flex;flex-direction:column;gap:14px">
      <div style="background:var(--accent);color:var(--on-accent);border-radius:15px;padding:18px;box-shadow:var(--shadow)">
        <h3 style="margin:0 0 4px;font-size:14.5px;font-weight:700"><%= t.quick_add %></h3>
        <p style="margin:0 0 14px;font-size:12.5px;opacity:.85"><%= t.quick_add_sub %></p>
        <a href="/admin/products/new" style="width:100%;height:42px;border-radius:10px;background:var(--on-accent);color:var(--accent);font-size:14px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
          <%= t.add_product %>
        </a>
      </div>
      <div style="background:var(--surface);border:1px solid var(--border);border-radius:15px;padding:16px;box-shadow:var(--shadow-sm)">
        <h3 style="margin:0 0 12px;font-size:14.5px;font-weight:700"><%= t.by_category %></h3>
        <div style="display:flex;flex-direction:column;gap:11px">
          <% catBars.forEach(function(c){ %>
            <div>
              <div style="display:flex;justify-content:space-between;font-size:12.5px;margin-bottom:5px"><span style="font-weight:600"><%= c.name %></span><span class="mono" style="color:var(--muted)"><%= c.count %></span></div>
              <div style="height:7px;border-radius:20px;background:var(--surface-3);overflow:hidden"><div style="height:100%;border-radius:20px;background:var(--accent);width:<%= c.pct %>%"></div></div>
            </div>
          <% }); %>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/admin-bottom') %>
